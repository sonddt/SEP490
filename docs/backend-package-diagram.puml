@startuml ShuttleUp_Backend_Packages
title ShuttleUp - Backend package diagram
skinparam packageStyle rectangle
skinparam defaultFontName Segoe UI

package "ShuttleUp.DAL" {
  package "ShuttleUp.DAL.Models" as DALModels {
    note right
      Entities, ShuttleUpDbContext
    end note
  }
  package "ShuttleUp.DAL.Repositories" as DALRepo {
    note right
      Concrete repos + Interfaces/
    end note
  }
}

package "ShuttleUp.BLL" {
  package "ShuttleUp.BLL.DTOs" as BLLDTO
  package "ShuttleUp.BLL.Interfaces" as BLLInt
  package "ShuttleUp.BLL.Services" as BLLSvc
}

package "ShuttleUp.Backend" {
  package "ShuttleUp.Backend.Controllers" as BECtrl
  package "ShuttleUp.Backend.Hubs" as BEHub
  package "ShuttleUp.Backend.Models" as BEModels
}

' Project-level dependencies (csproj)
ShuttleUp.BLL ..> ShuttleUp.DAL : <<ProjectReference>>
ShuttleUp.Backend ..> ShuttleUp.BLL : <<ProjectReference>>
ShuttleUp.Backend ..> ShuttleUp.DAL : <<ProjectReference>>

' Typical code dependencies
BLLSvc --> DALRepo
BLLSvc --> DALModels
BECtrl --> BLLInt
BECtrl --> BLLDTO
BECtrl --> DALModels

@enduml
